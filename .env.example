NODE_ENV=development

PORT=4000
APP_URL=http://localhost:5173
APP_URLS=http://localhost:5173,http://127.0.0.1:5173
API_URL=http://localhost:4000

# Supabase السحابي — ضع SUPABASE_DB_PASSWORD ثم: npm run setup:supabase-db
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_REGION=eu-west-1
SUPABASE_DB_PASSWORD=
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=

# محلي (Docker Supabase) أو يُستبدل بعد setup:supabase-db
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@localhost:54322/postgres

JWT_SECRET=niha-secret-key-change-in-production
JWT_EXPIRES_IN=24h

DEFAULT_TIMEZONE=Africa/Cairo
DEFAULT_CURRENCY=EGP

VITE_API_URL=http://localhost:4000/api
VITE_ELECTRON=0

# Desktop production build (npm run build:desktop):
# VITE_API_URL=https://niha-jxjq.onrender.com/api
# VITE_ELECTRON=1

# Desktop release to GitHub — ضع التوكن في ملف .env المحلي فقط (لا تضعه هنا)
GH_TOKEN=
